# Mr. Kim's Cafe — 자동 QA & 리포트 에이전트 환경변수
# 실제 값은 .env 에 저장 (gitignore 됨). 절대 커밋 금지.

# ─── QA 대상 ──────────────────────────────────────────────────────────────────
QA_TARGET_URL=http://localhost:3000

# ─── Daily Report 자동 로그인 자격 ────────────────────────────────────────────
# /api/cashier/login 에 사용 — 매출 조회용 cashier 계정
CASHIER_LOGIN_NAME=
CASHIER_LOGIN_PASSWORD=

# /api/auth/login 에 사용 — 재고 조회용 admin 계정 (선택)
ADMIN_LOGIN_USER=
ADMIN_LOGIN_PASSWORD=

# ─── 이메일 (Gmail SMTP 추천) ─────────────────────────────────────────────────
# Gmail은 2FA 켜고 https://myaccount.google.com/apppasswords 에서 앱 비밀번호 발급
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=aliatheerzamzam@gmail.com
SMTP_PASS=                # 16자리 앱 비밀번호 (공백 없이)
REPORT_EMAIL_FROM=aliatheerzamzam@gmail.com
REPORT_EMAIL_TO=aliatheerzamzam@gmail.com

# ─── WhatsApp (Twilio Sandbox) ────────────────────────────────────────────────
# https://www.twilio.com/console/sms/whatsapp/sandbox 에서 sandbox 가입
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886    # Twilio sandbox 기본 번호
WHATSAPP_TO=whatsapp:+9647XXXXXXXXX           # 본인 WhatsApp 번호 (국가코드 포함)
